{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LessonOutput",
  "description": "Output do Diretor de Apresentação — o lesson.json final no formato consumido pela plataforma (mesmo contrato de docs/lesson-contract-mvp-v1.md e lessons/mind-task-flow/lesson.json). Conteúdo pedagógico (label/content) e mapeamento (viewId/walkthrough/node/nodes) são sempre herdados do roteiro_mapeado original, nunca reescritos por este agente.",
  "type": "object",
  "required": ["id", "title", "version", "steps"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "viewId": { "type": ["string", "null"] },
    "walkthroughStart": { "type": ["integer", "null"] },
    "walkthroughEnd": { "type": ["integer", "null"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "camera", "content"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string", "minLength": 1 },
          "content": { "type": "string" },
          "camera": {
            "type": "object",
            "required": ["preset"],
            "additionalProperties": false,
            "properties": {
              "preset": {
                "enum": [
                  "overview",
                  "walkthrough-start",
                  "walkthrough",
                  "focus",
                  "cluster",
                  "consolidate"
                ]
              },
              "node": { "type": ["string", "null"] },
              "nodes": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "diagram": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["source", "generatedModule", "defaultView"],
      "properties": {
        "source": { "type": "string" },
        "generatedModule": { "type": "string" },
        "defaultView": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "director_agent": { "type": "string" },
        "model": { "type": "string" },
        "director_notes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Observações advisory do LLM (não bloqueiam publicação, servem pra revisão humana)"
        }
      }
    }
  }
}
